# ══════════════════════════════════════════════════════
# SportAccess – Variables de entorno
# Copia este archivo como .env y rellena los valores
# ══════════════════════════════════════════════════════

# ── Base de datos ──────────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=tu_password_seguro

# ── Firebase ───────────────────────────────────────────
# Ruta ABSOLUTA al fichero JSON de credenciales de Firebase Admin SDK
# Descárgalo desde Firebase Console → Configuración del proyecto → Cuentas de servicio
FIREBASE_CONFIG_PATH=/ruta/absoluta/a/firebase-service-account.json

# ── CORS ───────────────────────────────────────────────
# Orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Stripe (opcional) ──────────────────────────────────
# STRIPE_API_KEY=sk_test_...
